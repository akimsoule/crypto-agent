// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Table existante pour les gems de CryptoGemHunter
model CryptoGemProject {
  id                       Int       @id @default(autoincrement())
  coinId                   String    @unique
  symbol                   String
  name                     String
  currentPrice             Float
  marketCap                Float
  marketCapRank            Int
  priceChangePercentage24h Float
  volume24h                Float
  totalVolume              Float
  circulatingSupply        Float
  maxSupply                Float?
  ath                      Float
  athChangePercentage      Float
  gemScore                 Float?
  sentimentScore           Float?
  sentimentMentions        Int?
  sentimentPositiveRatio   Float?
  needsSentimentAnalysis   Boolean   @default(false)
  lastUpdated              DateTime  @default(now())
  lastAnalyzed             DateTime?
  lastTelegramSent         DateTime?

  // Relations avec les investissements
  investments CryptoInvestment[]

  @@map("crypto_gem_projects")
}

// Table existante pour les alertes
model CryptoGemAlert {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  project   String
  priority  String
  createdAt DateTime @default(now())

  @@map("crypto_gem_alerts")
}

// Table existante pour l'état du système
model CryptoGemState {
  id               Int       @id @default(autoincrement())
  currentPage      Int       @default(1)
  maxPages         Int       @default(20)
  batchSize        Int       @default(100)
  lastCycleStart   DateTime  @default(now())
  lastFullAnalysis DateTime?
  processPhase     String    @default("FETCH") // FETCH, ANALYZE, COMPLETE
  isProcessing     Boolean   @default(false)

  @@map("crypto_gem_states")
}

// Nouvelle table pour les profils d'investisseurs
model InvestorProfile {
  id              String   @id
  name            String
  type            String // conservative, balanced, aggressive, contrarian, momentum
  riskTolerance   Float
  maxPositionSize Float // Pourcentage
  holdingPeriod   Int // En jours
  sellThreshold   Float // Profit % avant vente
  stopLoss        Float // Perte % avant vente
  sentimentWeight Float // 0-1
  technicalWeight Float // 0-1
  description     String
  initialBalance  Float    @default(10000)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  investments        CryptoInvestment[]
  portfolioSnapshots CryptoPortfolioSnapshot[]

  @@map("investor_profiles")
}

// Nouvelle table pour les investissements
model CryptoInvestment {
  id               String   @id
  investorId       String
  coinId           String
  symbol           String
  name             String
  action           String // BUY, SELL, HOLD
  amount           Float // Montant en USD
  price            Float // Prix d'achat/vente
  quantity         Float // Quantité de crypto
  timestamp        DateTime @default(now())
  reason           String // Raison de l'investissement
  gemScore         Float?
  sentiment        Float?
  expectedHoldDays Int
  targetProfit     Float?
  stopLoss         Float?

  // Nouveau champ pour indiquer le type de marché (SPOT, MARGIN, FUTURES...)
  marketType String @default("SPOT")

  // Métadonnées pour le suivi
  isExecuted     Boolean @default(true)
  executionPrice Float? // Prix réel d'exécution
  fees           Float? // Frais de transaction
  notes          String?

  // Relations
  investor   InvestorProfile  @relation(fields: [investorId], references: [id])
  gemProject CryptoGemProject @relation(fields: [coinId], references: [coinId])

  @@index([investorId])
  @@index([coinId])
  @@index([timestamp])
  @@map("crypto_investments")
}

// Nouvelle table pour les snapshots de portefeuille
model CryptoPortfolioSnapshot {
  id                 Int      @id @default(autoincrement())
  investorId         String
  timestamp          DateTime @default(now())
  totalValue         Float
  cashBalance        Float
  totalReturn        Float
  totalReturnPercent Float
  winRate            Float
  avgWinPercent      Float
  avgLossPercent     Float
  maxDrawdown        Float
  totalTrades        Int
  winningTrades      Int
  losingTrades       Int
  activePositions    Int

  // Relations
  investor  InvestorProfile  @relation(fields: [investorId], references: [id])
  positions CryptoPosition[]

  @@index([investorId])
  @@index([timestamp])
  @@map("crypto_portfolio_snapshots")
}

// Nouvelle table pour les positions
model CryptoPosition {
  id                   Int      @id @default(autoincrement())
  snapshotId           Int
  coinId               String
  symbol               String
  name                 String
  quantity             Float
  avgBuyPrice          Float
  currentPrice         Float
  unrealizedPnL        Float
  unrealizedPnLPercent Float
  daysSinceEntry       Int
  lastUpdated          DateTime @default(now())

  // Relations
  snapshot CryptoPortfolioSnapshot @relation(fields: [snapshotId], references: [id])

  @@index([snapshotId])
  @@index([coinId])
  @@map("crypto_positions")
}

// Nouvelle table pour les métriques de simulation
model CryptoSimulationRun {
  id                    Int      @id @default(autoincrement())
  runId                 String   @unique
  timestamp             DateTime @default(now())
  gemsAnalyzed          Int
  totalInvestments      Int
  totalBuyOrders        Int
  totalSellOrders       Int
  totalAmountInvested   Float
  totalAmountSold       Float
  activeInvestors       Int
  bestPerformerName     String?
  bestPerformerReturn   Float?
  worstPerformerName    String?
  worstPerformerReturn  Float?
  avgReturnAllInvestors Float?

  // Métadonnées
  simulationType String  @default("STANDARD") // STANDARD, PERFORMANCE_TEST, QUICK
  durationMs     Int?
  success        Boolean @default(true)
  errorMessage   String?

  @@index([timestamp])
  @@index([runId])
  @@map("crypto_simulation_runs")
}

// Nouvelle table pour les statistiques quotidiennes
model CryptoDailyStats {
  id                   Int      @id @default(autoincrement())
  date                 DateTime @unique
  totalSimulations     Int      @default(0)
  totalInvestments     Int      @default(0)
  totalVolume          Float    @default(0)
  avgGemsPerSimulation Float    @default(0)
  topPerformingCoin    String?
  topPerformingGain    Float?
  mostTradedCoin       String?
  mostTradedVolume     Float?
  bestInvestor         String?
  bestInvestorReturn   Float?

  @@index([date])
  @@map("crypto_daily_stats")
}

// Nouvelle table pour les signaux sociaux (pour partage réseaux sociaux)
model CryptoSocialSignal {
  id                 Int       @id @default(autoincrement())
  signalType         String // INVESTMENT, PERFORMANCE, ALERT, TREND
  investorId         String?
  coinId             String?
  title              String
  content            String
  hashtags           String? // JSON array
  sentiment          String // POSITIVE, NEGATIVE, NEUTRAL
  engagement         Int       @default(0)
  isPublished        Boolean   @default(false)
  publishedAt        DateTime?
  platforms          String? // JSON array: twitter, linkedin, etc.
  performanceMetrics String? // JSON object

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signalType])
  @@index([isPublished])
  @@index([createdAt])
  @@map("crypto_social_signals")
}

// Table pour les configurations système
model CryptoSystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique
  configValue String // JSON string
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("crypto_system_configs")
}

// Table pour les abonnés à la newsletter
model NewsletterSubscription {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  isActive      Boolean  @default(true)
  source        String   @default("web") // web, api, import
  preferences   String? // JSON object pour les préférences
  confirmedAt   DateTime?
  unsubscribedAt DateTime?
  lastEmailSent DateTime?
  emailsSent    Int      @default(0)
  bounced       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([isActive])
  @@index([createdAt])
  @@map("newsletter_subscriptions")
}
