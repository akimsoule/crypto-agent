# Example environment file for the project. Do NOT commit secrets to source control.

# Configuration de la base de données
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cryptoagent?schema=public"

WEBSITE_URL="http://localhost:8888"

# Configuration Facebook
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_PAGE_NAME="Your Facebook Page Name"

# Configuration JWT pour l'authentification
JWT_SECRET="your_jwt_secret_here"

# Token d'administration pour l'API de seed
ADMIN_API_TOKEN="your_admin_api_token"

# Variables optionnelles pour Telegram
TELEGRAM_KEY="your_telegram_bot_token"
TELEGRAM_GROUP_ID="your_telegram_group_id"

# Configuration Resend pour l'envoi d'emails
RESEND_API_KEY="your_resend_api_key"
RESEND_FROM_EMAIL="Crypto Investors Hub <newsletter@crypto-investors-hub.com>"
RESEND_REPLY_TO="noreply@crypto-investors-hub.com"
REPLY_TO_EMAIL="noreply@yourdomain.com"

# Configuration Email (optionnelle - service alternatif)
EMAIL_API_KEY="your_email_api_key"
FROM_EMAIL="noreply@yourdomain.com"
FROM_NAME="Your App Name"

# Configuration générale de l'application
APP_ENV="development"

# Comptes Bitget / API (placeholders — renseignez vos clés en local/.env)
ACCOUNT_API_KEY_MAIN=bg_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACCOUNT_API_KEY_SECOND=bg_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACCOUNT_SECRET_KEY_MAIN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACCOUNT_SECRET_KEY_SECOND=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_PASS=your_api_passphrase
