# Configuration de la base de données
DATABASE_URL="postgresql://username:password@localhost:5432/crypto_agent"

WEBSITE_URL="http://localhost:8888"

# Configuration Facebook
FB_APP_ID="your_facebook_app_id"
FB_APP_SECRET="your_facebook_app_secret"
FB_PAGE_NAME="Your Facebook Page Name"

# Configuration JWT pour l'authentification
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Token d'administration pour l'API de seed
ADMIN_API_TOKEN="your-admin-api-token-for-seeding"

# Variables optionnelles pour Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# Configuration Resend pour l'envoi d'emails
RESEND_API_KEY="your_resend_api_key"
RESEND_FROM_EMAIL="Crypto Investors Hub <newsletter@crypto-investors-hub.com>"
RESEND_REPLY_TO="noreply@crypto-investors-hub.com"
REPLY_TO_EMAIL="noreply@yourdomain.com"

# Configuration Email (optionnelle - service alternatif)
EMAIL_API_KEY="your_email_api_key"
FROM_EMAIL="noreply@yourdomain.com"
FROM_NAME="Your App Name"

# Configuration générale de l'application
APP_ENV="development"

# Comptes Bitget / API (renseignez vos clés en local/.env)
ACCOUNT_SECRET_KEY_MAIN="your_main_secret_key"
ACCOUNT_SECRET_KEY_SECOND="your_second_secret_key"
API_PASS="your_api_pass"
