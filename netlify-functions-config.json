      "prisma",
      "@prisma/client", 
      "jsonwebtoken",
      "react",
      "react-dom",
      "typescript",
      "vite"
    ],
    "minify": true,
    "sourceMap": false,
    "esbuild": {
      "bundle": true,
      "minify": true,
      "target": ["node16"],
      "platform": "node",
      "external": [
        "prisma",
        "@prisma/client", 
        "react", 
        "react-dom",
        "jsonwebtoken"
      ]
    }
  }
}
