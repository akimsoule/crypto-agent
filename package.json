{
  "name": "crypto-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "start": "vite",
    "build": "prisma generate && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "setup-investors": "tsx netlify/src/domain/investor/setupInvestors.ts",
    "test-cron": "tsx netlify/src/investor/testCron.ts",
    "test-gem-hunter": "tsx netlify/src/testCronGemHunter.ts",
    "investor-status": "tsx -e \"import { getInvestorsStatus } from './netlify/src/domain/investor/setupInvestors.ts'; getInvestorsStatus().then(console.log)\"",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "reset:investors": "tsx scripts/reset-data.ts --investors",
    "reset:gems": "tsx scripts/reset-data.ts --gems",
    "reset:portfolios": "tsx scripts/reset-data.ts --portfolios",
    "reset:all": "tsx scripts/reset-data.ts --all",
    "reset:investors:prod": "ENV_FILE=.env.prod tsx scripts/reset-data.ts --investors",
    "reset:gems:prod": "ENV_FILE=.env.prod tsx scripts/reset-data.ts --gems",
    "reset:portfolios:prod": "ENV_FILE=.env.prod tsx scripts/reset-data.ts --portfolios",
    "reset:all:prod": "ENV_FILE=.env.prod tsx scripts/reset-data.ts --all",
    "deploy:seed": "npx prisma migrate deploy && npx prisma generate && npm run db:seed",
    "deploy:test": "./scripts/deploy.sh",
    "env:validate": "tsx scripts/validate-env.ts",
    "env:check": "npm run env:validate",
    "gem-hunter": "tsx scripts/runGemHunter.ts",
    "test-cooldown": "tsx scripts/test-investor-cooldown.ts",
    "test-facebook": "tsx netlify/test/testFacebookToken.ts",
    "check-facebook": "tsx scripts/checkFacebookConfig.ts",
    "update-facebook-token": "tsx scripts/updateFacebookToken.ts",
    "test-resend-templates": "tsx scripts/test-resend-templates.ts",
    "dev:enable-test-functions": "cp netlify/functions-dev/*.mts netlify/functions/",
    "dev:disable-test-functions": "rm -f netlify/functions/test-*.mts netlify/functions/seed-database.mts"
  },
  "dependencies": {
    "@netlify/functions": "^3.1.10",
    "@prisma/client": "^6.14.0",
    "@react-email/components": "^0.5.0",
    "@react-email/render": "^1.2.0",
    "@tanstack/react-query": "^5.85.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.17.1",
    "@types/pg": "^8.15.5",
    "axios": "^1.11.0",
    "chalk": "^5.6.0",
    "chart.js": "^4.4.0",
    "dotenv": "^17.2.1",
    "indicatorts": "^2.2.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.539.0",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.1.1",
    "react-email": "^4.2.8",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.30.1",
    "resend": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.0.50",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "prisma": "^6.14.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
